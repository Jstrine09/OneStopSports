# ─────────────────────────────────────────────────────────────────────────────
# OneStopSports — Environment Variables Example
#
# Copy this file to application-local.yml and fill in the real values.
# application-local.yml is gitignored so your secrets never get committed.
#
# How to use:
#   cp .env.example src/main/resources/application-local.yml
#   (then edit application-local.yml with your real keys)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# The local Postgres database — started via docker-compose up -d
# Default user/password match what's in docker-compose.yml
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/onestopsports  # database name must match docker-compose
    username: postgres                                   # default Postgres superuser
    password: YOUR_POSTGRES_PASSWORD                     # set this to whatever you used in docker-compose

# ── Football API (football-data.org) ──────────────────────────────────────────
# Free tier key — sign up at https://www.football-data.org/client/register
# Rate limit: 10 requests/min — the DataLoader sleeps between calls to stay under this
external-api:
  football-data:
    api-key: YOUR_FOOTBALL_DATA_API_KEY

# ── NBA API (balldontlie.io) ──────────────────────────────────────────────────
# Free tier key — sign up at https://www.balldontlie.io/
# Used by NbaDataLoader to seed teams/rosters and by NbaApiService for live scores
  nba:
    api-key: YOUR_BALLDONTLIE_API_KEY

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Base64-encoded secret used to sign JWT tokens.
# Generate a strong one with: openssl rand -base64 64
# If you change this, all existing tokens are immediately invalidated (users get logged out)
jwt:
  secret: YOUR_BASE64_ENCODED_JWT_SECRET
