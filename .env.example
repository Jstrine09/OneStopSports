# ─────────────────────────────────────────────────────────────────────────────
# OneStopSports — Environment Variables
#
# Two ways to run the app:
#
#   A) Local dev (Maven):
#      Copy this to src/main/resources/application-local.yml and fill in values.
#      Run: mvn spring-boot:run -Dspring-boot.run.profiles=local
#
#   B) Full Docker Compose stack (app + Postgres + Redis all containerised):
#      Copy this file to .env and fill in values.
#      Run: docker-compose up --build
#      On first boot the data loaders seed the DB automatically (~2 min).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the onestopsports Postgres database.
# Must match POSTGRES_PASSWORD in docker-compose.yml (defaults to "password").
DB_PASSWORD=password

# ── Football API (football-data.org) ──────────────────────────────────────────
# Free tier key — sign up at https://www.football-data.org/client/register
# Rate limit: 10 requests/min — the DataLoader sleeps between calls automatically.
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ── NBA + NFL APIs ────────────────────────────────────────────────────────────
# Both use ESPN's unofficial public API — no key required, nothing to set here.

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Base64-encoded secret used to sign JWT tokens.
# Generate one: openssl rand -base64 64
# Changing this invalidates all existing sessions (all users get logged out).
JWT_SECRET=your_base64_encoded_jwt_secret_here
